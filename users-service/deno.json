{
  "tasks": {
    "dev": "deno run --watch --allow-net --allow-env --allow-read src/index.ts",
    "start": "deno run --allow-net --allow-env --allow-read src/index.ts",
    "db:generate": "deno -A npm:drizzle-kit generate",
    "db:migrate": "deno run --allow-net --allow-env --allow-read src/identity/infrastructure/migrate.ts",
    "db:seed": "deno run --allow-net --allow-env --allow-read src/identity/infrastructure/seed.ts",
    "test": "deno test --allow-net --allow-env --allow-read tests/",
    "lint": "deno lint",
    "fmt": "deno fmt"
  },
  "imports": {
    "@oak/oak": "jsr:@oak/oak@^17",
    "@oak/oak/": "jsr:@oak/oak@^17/",
    "drizzle-orm": "npm:drizzle-orm@^0.45.0",
    "drizzle-orm/": "npm:drizzle-orm@^0.45.0/",
    "postgres": "npm:postgres@^3.4.8",
    "rxjs": "npm:rxjs@^7.8.0",
    "amqplib": "npm:amqplib@^0.10.7",
    "drizzle-kit": "npm:drizzle-kit@^0.31.0",
    "@std/assert": "jsr:@std/assert@^1"
  },
  "compilerOptions": {
    "strict": true
  },
  "nodeModulesDir": "auto"
}
