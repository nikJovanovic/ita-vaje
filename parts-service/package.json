{
  "name": "parts-service",
  "version": "1.0.0",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "test": "bun test",
    "lint": "biome check",
    "format": "biome format --write",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun run src/catalog/infrastructure/migrate.ts",
    "db:seed": "bun run src/catalog/infrastructure/seed.ts"
  },
  "dependencies": {
    "@elysiajs/openapi": "^1.4.0",
    "drizzle-orm": "^0.44.0",
    "elysia": "^1.4.27",
    "postgres": "^3.4.8"
  },
  "devDependencies": {
    "bun-types": "^1.3.10",
    "@biomejs/biome": "^2.2.0",
    "drizzle-kit": "^0.31.0"
  }
}
