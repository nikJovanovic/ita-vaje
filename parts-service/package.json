{
  "name": "parts-service",
  "version": "1.0.0",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "test": "bun test",
    "lint": "biome lint src",
    "format": "biome check --write",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun run src/catalog/infrastructure/migrate.ts",
    "db:seed": "bun run src/catalog/infrastructure/seed.ts"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.14.3",
    "@grpc/proto-loader": "^0.8.0",
    "@grpc/reflection": "^1.0.4",
    "drizzle-orm": "^0.44.0",
    "postgres": "^3.4.8"
  },
  "devDependencies": {
    "bun-types": "^1.3.10",
    "@biomejs/biome": "^2.2.0",
    "drizzle-kit": "^0.31.0"
  }
}
