{
  "name": "builds-service",
  "version": "1.0.0",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "test": "bun test",
    "lint": "biome lint src",
    "format": "biome check --write",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun run src/build-management/infrastructure/migrate.ts",
    "db:seed": "bun run src/build-management/infrastructure/seed.ts"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.14.3",
    "@grpc/proto-loader": "^0.8.0",
    "@hono/standard-validator": "^0.2.2",
    "@scalar/hono-api-reference": "^0.10.4",
    "@valibot/to-json-schema": "^1.6.0",
    "drizzle-orm": "^0.44.0",
    "hono": "^4.12.8",
    "hono-openapi": "^1.3.0",
    "postgres": "^3.4.8",
    "valibot": "^1.3.1"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@biomejs/biome": "^2.2.0",
    "drizzle-kit": "^0.31.0"
  }
}
